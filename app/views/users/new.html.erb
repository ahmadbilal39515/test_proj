<% content_for :title, "New user" %>

<h2>Sign Up</h2>
<h2>Sign Up</h2>
<%= form_with model: @user, local: true do |form| %>
  <div>
    <%= form.label :email %>
    <%= form.email_field :email, required: true %>
  </div>
  <div>
    <%= form.label :password %>
    <%= form.password_field :password, required: true %>
  </div>
  <div>
    <%= form.submit "Sign Up" %>
  </div>
<% end %>

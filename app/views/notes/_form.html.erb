<h2>New Note</h2>
<%= form_with model: @note, local: true do |form| %>
  <p>
    <%= form.label :title %><br>
    <%= form.text_field :title %>
  </p>

  <p>
    <%= form.label :message %><br>
    <%= form.text_area :message %>
  </p>

  <p>
    <%= form.submit "Create Note" %>
  </p>
<% end %>

<%= link_to "Back to Notes", notes_path %>
